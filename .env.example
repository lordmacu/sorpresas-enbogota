# === LLM para generar contenido SEO de productos ===
# Script: scripts/generate-seo.mjs (npm run seo:generate)
# Copia este archivo a .env.local (o .env) y rellena LLM_API_KEY.

# Requerido. API key de tu cuenta MiniMax (platform.minimax.io > API Keys).
# La MISMA key sirve para el Token Plan y para pay-as-you-go: lo que decide
# qué cuota se consume es el ENDPOINT (LLM_BASE_URL), no la key.
LLM_API_KEY=sk-tu-api-key-de-minimax-aqui

# Opcional. URL base de la API.
#   >>> Token Plan (cuota del plan, NO pay-as-you-go):
#   https://api.minimax.io/anthropic
#   Pay-as-you-go MiniMax (consume saldo): https://api.minimax.io/v1
#   OpenAI: https://api.openai.com/v1   |   OpenRouter: https://openrouter.ai/api/v1
LLM_BASE_URL=https://api.minimax.io/anthropic

# Opcional. Modelo. Usa el que muestre tu página de Token Plan.
#   MiniMax: MiniMax-M2.5 (actual), MiniMax-M2.1, MiniMax-M3
LLM_MODEL=MiniMax-M2.5

# Opcional. Protocolo: auto | openai | anthropic (default auto).
# "auto" detecta por la URL: .../anthropic -> anthropic, resto -> openai.
LLM_API_STYLE=auto

# Opcional. response_format json_object: auto | on | off (default auto).
# Solo aplica al estilo openai; con el endpoint anthropic se ignora.
LLM_JSON_MODE=auto
